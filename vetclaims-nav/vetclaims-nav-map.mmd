    %% ================= CONVERSION PATH (the money funnel) =================
    OPTIN@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/60-optin-landing.png", label: "SEE IF I QUALIFY — The lead funnel on a separate domain (optin.vetclaims.ai). Opens with 'Your rating increases... or We Pay You', a Purple Heart Foundation endorsement and 'Featured In' logos. Runs a multi-step qualification quiz with an SMS opt-in baked in; the contact form at the end submits a real sales lead.", pos: "b", w: 560, h: 350 }
    PRICING@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/02-pricing.png", label: "PRICING — One flat fee, no cut of your backpay (their core wedge vs attorneys). Leads with 'Hate unknown pricing?' then lays out the $1,250 'Complete Care' package: nexus letters, buddy statements, C&amp;P prep, VA case-law citations, and a 100% satisfaction guarantee. Framed as far cheaper than the %-of-backpay model.", pos: "b", w: 560, h: 350 }
    LOGIN@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/70-client-login.png", label: "CLIENT LOGIN — A separate portal app (vetclaims.app) for existing paying clients. Simple 'Welcome back to VetClaims!' email login with Continue + Troubleshoot. The portal interior is gated and was not captured (no client account).", pos: "b", w: 560, h: 350 }
    SALES["📞 Booking calendar → free consultation / sales call<br/>+ email &amp; SMS nurture sequence<br/><i>(gated — the calendar only loads after a real lead submit; not captured to avoid live sales contact)</i>"]

    %% ---- See-if-Qualify funnel = their onboarding (captured step by step) ----
    FQ1@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/funnel/cards/01-do-you-currently-have-a-va-rating.png", label: "Funnel Q1 — 'Do you currently have a VA rating?' (Yes / No). Phase 1 'Questionnaire'; the first qualifier that routes the veteran.", pos: "b", w: 520, h: 325 }
    FQ2@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/funnel/cards/02-are-you-currently-rated-100.png", label: "Funnel Q2 — 'Are you currently rated 100%?' (Yes / No). Screens out veterans already at the cap (no upside to sell them).", pos: "b", w: 520, h: 325 }
    FQ3@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/funnel/cards/03-when-do-you-want-to-start.png", label: "Funnel Q3 — 'When do you want to start?' (Immediately / Tomorrow / Next Week) plus an 'I understand this is for a free consultation' acknowledgement. Sets urgency + frames the call.", pos: "b", w: 520, h: 325 }
    FCONTACT@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/funnel/cards/04-contact-form-filled.png", label: "Phase 2 'Check Spots' — contact form (first/last name, email, phone + SMS opt-in). 'Check for availability' POSTs the lead to HubSpot + a Zapier webhook + their leadfi-prequal API.", pos: "b", w: 520, h: 325 }
    FREEVALUE@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/funnel/cards/05-phase3-after-submit.png", label: "Phase 3 'Free Value' — price qualifier: 'Our only fee is $1,250 — are you OK with that? Keep 100% of your backpay & increase. Payment plans available.' Confirms budget BEFORE booking the call.", pos: "b", w: 520, h: 325 }

    %% ================= VA BENEFITS (hub + dropdown) =================
    VAB@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/10-va-benefits-hub.png", label: "📚 VA BENEFITS — The educational hub, 'A Complete Guide for Veterans'. Explains how the VA system works and why ratings feel inconsistent, then branches into Rating Increase, Disability Pay, filing/winning claims, C&amp;P Exams, Appeals and the PACT Act. Sits at the top of a large SEO content tree that feeds the funnel.", pos: "b", w: 560, h: 350 }
    RI@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/11-rating-increase.png", label: "Rating Increase — How and when to push for a higher rating. Covers signs a condition warrants an increase, the evidence the VA weighs, the step-by-step filing process, and the reduction risk that can backfire. Closes with FAQs and a 'Book a strategy call' CTA.", pos: "b", w: 520, h: 325 }
    DP@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/12-disability-pay.png", label: "VA Disability Pay — How compensation actually works. Breaks down who qualifies, how the VA decides the amount, the 2026 rate tables (with dependents), extra pay most vets miss, and lump-sum back pay vs monthly payments. Aimed at veterans who suspect they are underpaid.", pos: "b", w: 520, h: 325 }
    AP@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/13-appeals.png", label: "Appeals — What to do after a denial or low rating, in plain language. Walks through pinpointing what the VA got wrong and the three options (Supplemental Claim, Higher-Level Review, Board Appeal), including Board dockets and realistic timelines. Sets expectations for what an appeal can and cannot do.", pos: "b", w: 520, h: 325 }
    CP@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/14-cp-exams.png", label: "C&amp;P Exams — What the Compensation &amp; Pension exam is and how to prepare. Explains why the VA schedules one, what actually happens in the room, how the results get used, and the common mistakes that cost veterans benefits. Reframes what 'passing' a C&amp;P exam really means.", pos: "b", w: 520, h: 325 }
    PACT@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/15-pact-act.png", label: "PACT Act &amp; Toxic Exposure — How the VA decides burn-pit, Agent Orange and toxin claims. Covers what the law changed, who it applies to, the presumptive-condition list, and refiling if you were denied before the PACT Act. Ties back into C&amp;P exams and the wider claim.", pos: "b", w: 520, h: 325 }

    %% ================= CONDITIONS =================
    COND@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/20-conditions.png", label: "🩺 CONDITIONS — Hub for 'VA Disability Ratings by Condition', linking to 30+ pages (PTSD, tinnitus, sleep apnea, GERD, back pain, ~10 arthritis variants, etc.). Explains how ratings are assigned by functional impact, why they don't go higher, and how secondary conditions stack. Filterable by category: Mental Health, Musculoskeletal, Neurological, Digestive.", pos: "b", w: 560, h: 350 }

    %% ================= COMPANY =================
    ABOUT@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/30-about.png", label: "About — Veteran-led, AI-powered claim prep that claims to handle 99% of the work. Sections: Our Story, How We Do It, Our Four Pillars, and an 'Anti-Shark, Pro-Veteran' stance positioning them against attorneys. Introduces the team and the evidence-backed (nexus + case-law) approach.", pos: "b", w: 520, h: 325 }
    FOUNDER@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/31-founder-story.png", label: "Founder Story — The personal narrative of founder/CEO Lukas Simianer, a Purple Heart veteran. Walks from poverty to service, the hard parts no one talks about, and why he built VetClaims to fix the VA claims process. A heavy trust and credibility play.", pos: "b", w: 520, h: 325 }
    CONTACT@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/32-contact.png", label: "Contact — A lean contact page. Pushes the phone line (737) 344-4399 alongside the 'See if I Qualify' path, positioned as honest guidance from veterans who understand. Minimal beyond the call/qualify CTAs.", pos: "b", w: 520, h: 325 }

    %% ================= TOOLS (priority) =================
    CALC@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/40-calculator.png", label: "VA Disability Calculator — A genuinely useful free tool on its own app (calc.vetclaims.ai). Step 1: add disabilities by clicking a body part + rating %; Step 2: add dependents; then it shows your combined rating and monthly pay. Their strongest free top-of-funnel hook, wired to a 'Book Free Strategy Call' CTA.", pos: "b", w: 560, h: 350 }
    CALCR@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/41-calculator-result.png", label: "↳ Calculator IN ACTION — The same tool, populated. Adding 50% + 30% + 20% computes a combined 70% rating and $1,759.19/mo, with each condition listed and a live rating dial. Shows how the tool captures intent before handing the veteran to sales.", pos: "b", w: 560, h: 350 }
    PP@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/42-patriots-portal.png", label: "Patriots Portal — An aggressive landing page ('Skip the Bullsh*t, Get the Rating YOU DESERVE'). Pitched as a free tool/resource hook but routes straight back into the same qualify / strategy-call funnel. Light on content, heavy on CTA.", pos: "b", w: 560, h: 350 }
    FNT@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/43-free-nexus-templates.png", label: "Free Nexus Templates — Despite the nav label, this is a deep article ('Nexus Letter Examples: What a Strong VA Medical Opinion Looks Like'). It breaks down what a strong nexus letter includes, direct vs secondary service-connection examples, what makes one weak, and who should write it. Downloadable templates act as the lead magnet.", pos: "b", w: 560, h: 350 }

    %% ================= BLOG =================
    BLOG@{ img: "https://raw.githubusercontent.com/dzuniga5/veteran-tools-teardown-assets/main/vetclaims-nav/cards/50-blog.png", label: "✍️ BLOG — The article index (21 posts) covering VA claims, rating increases, C&amp;P exams, secondary conditions and appeals. Branded 'written by veterans, for veterans'. Pure SEO / top-of-funnel content all pointing back to the same CTAs.", pos: "b", w: 560, h: 350 }

